---
import Layout from '../layouts/Layout.astro';
import { listHouses } from '../lib/houses';
const houses = listHouses();
---
<Layout title="Product Purveyor">
  <header class="site-header">
    <h1>Product Purveyor</h1>
    <p class="tag">Your local-first home procurement workspace.</p>
  </header>

  <h2>Houses</h2>
  {houses.length === 0 ? (
    <p class="empty">No houses yet. Open Claude Code in this repo and say: <code>Set up a new house called &lt;name&gt;</code>.</p>
  ) : (
    <ul class="house-list">
      {houses.map((h) => (
        <li>
          <a href={`/${h.slug}/`}>
            <strong>{h.name}</strong>
            {h.address && <span class="addr">{h.address}</span>}
            {h.budget?.hard_cap_ils && <span class="cap">cap: &#8362;{h.budget.hard_cap_ils.toLocaleString()}</span>}
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>
