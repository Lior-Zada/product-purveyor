---
import Layout from '../../../layouts/Layout.astro';
import { listHouses, listItems, loadHouse, loadItemBySlug, stars, formatDate, daysSince } from '../../../lib/houses';
import type { Option, Reviews, ReviewSource, ReviewQuote, Feature } from '../../../lib/houses';
import { marked } from 'marked';

export function getStaticPaths() {
  const paths: Array<{ params: { house: string; item: string } }> = [];
  for (const house of listHouses()) {
    for (const item of listItems(house.slug)) {
      paths.push({ params: { house: house.slug, item: item.slug } });
    }
  }
  return paths;
}

const { house: houseSlug, item: itemSlug } = Astro.params;
const house = loadHouse(houseSlug!);
const item = loadItemBySlug(houseSlug!, itemSlug!);

if (!house || !item) {
  return Astro.redirect(`/${houseSlug}/`);
}

const bodyHtml = item.body ? marked.parse(item.body) : '';
const selected: Option = item.selected ?? {};
const upsell: Option[] = item.upsell_considered ?? [];
const alternatives: Option[] = item.alternatives_considered ?? [];
const features: Feature[] = selected.features ?? [];
const energy = item.energy ?? {};
const constraints = (item.constraints ?? {}) as Record<string, unknown>;
const selectedImageStyle = selected.image_url ? `background-image: url('${selected.image_url}');` : '';

function inline(s: string | undefined): string {
  if (!s) return '';
  return marked.parseInline(s) as string;
}

const verifiedDays = daysSince(selected.link_verified_date);
const verifiedStale = verifiedDays !== undefined && verifiedDays > 60;
---
<Layout title={`${item.title} — ${house.name}`}>
  <nav><a href={`/${house.slug}/`}>&larr; {house.name}</a></nav>

  <header class="item-header">
    <div class="card-head">
      <span class={`badge status-${item.status}`}>{item.status}</span>
      {item.priority && <span class="badge priority">{item.priority}</span>}
      {item.sequence && <span class="badge sequence">{item.sequence}</span>}
    </div>
    <h1>{item.title}</h1>
    {item.required_by && <p class="meta">Required by: {formatDate(item.required_by)}</p>}
    {item.date_needed && <p class="meta">Date needed: {formatDate(item.date_needed)}</p>}
  </header>

  <div class="item-detail-grid">
    <div class="left-col">
      {bodyHtml && (
        <section class="md-body">
          <Fragment set:html={bodyHtml} />
        </section>
      )}

      {features.length > 0 && (
        <section class="features">
          <h2>What makes this special</h2>
          <ul class="features-list">
            {features.map((f) => (
              <li>
                <div class="feature-name">{f.name}</div>
                {f.detail && <div class="feature-detail">{f.detail}</div>}
              </li>
            ))}
          </ul>
        </section>
      )}

      {selected.reviews && (
        <section class="reviews">
          <h2>Reviews</h2>
          <div class="reviews-summary">
            {selected.reviews.average_score !== undefined && (
              <>
                <span class="reviews-score">{selected.reviews.average_score.toFixed(1)}</span>
                <span class="reviews-score-max">/ {selected.reviews.score_max ?? 5}</span>
                <span class="reviews-stars">{stars(selected.reviews.average_score, selected.reviews.score_max ?? 5)}</span>
              </>
            )}
            {selected.reviews.total_reviews !== undefined && (
              <span class="reviews-count">{selected.reviews.total_reviews.toLocaleString()} reviews</span>
            )}
          </div>
          {selected.reviews.sources && selected.reviews.sources.length > 0 && (
            <div class="reviews-sources">
              {selected.reviews.sources.map((s: ReviewSource) => {
                const label = (
                  <>
                    <strong>{s.site}</strong>
                    <span>{s.score}{s.score_max ? `/${s.score_max}` : ''}{s.count !== undefined ? ` (${s.count})` : ''}</span>
                  </>
                );
                return s.url
                  ? <a class="reviews-source" href={s.url} target="_blank" rel="noopener" title={`Read reviews on ${s.site}`}>{label}</a>
                  : <span class="reviews-source">{label}</span>;
              })}
            </div>
          )}
          {selected.reviews.quotes && selected.reviews.quotes.length > 0 && (
            <div class="reviews-quotes">
              {selected.reviews.quotes.map((q: ReviewQuote) => (
                <div class={`review-quote ${q.sentiment ?? ''}`}>
                  <span class="quote">&ldquo;{q.quote}&rdquo;</span>
                  <span class="src">
                    {q.source_url
                      ? <a href={q.source_url} target="_blank" rel="noopener">{q.source} &nearr;</a>
                      : q.source}
                  </span>
                </div>
              ))}
            </div>
          )}
        </section>
      )}

      {alternatives.length > 0 && (
        <section>
          <h2>Alternatives considered</h2>
          <div class="alt-grid">
            {alternatives.map((alt) => {
              const altImageStyle = alt.image_url ? `background-image: url('${alt.image_url}');` : '';
              const altCard = (
                <>
                  <div class="alt-head">
                    <div class="alt-image" style={altImageStyle}></div>
                    <div class="alt-info">
                      <p class="alt-brand">{alt.brand ?? alt.provider}</p>
                      {alt.model && <p class="alt-model">{alt.model}</p>}
                      {alt.price_ils && <p class="alt-price">&#8362;{alt.price_ils.toLocaleString()}</p>}
                      {alt.reviews?.average_score !== undefined && (
                        <p class="alt-reviews">
                          <span class="stars">{stars(alt.reviews.average_score, alt.reviews.score_max ?? 5)}</span>
                          <span>{alt.reviews.average_score.toFixed(1)}</span>
                          {alt.reviews.total_reviews !== undefined && <span>&middot; {alt.reviews.total_reviews}</span>}
                        </p>
                      )}
                    </div>
                  </div>
                  {alt.why_skipped && <p class="alt-why" set:html={inline(alt.why_skipped)} />}
                </>
              );
              return alt.product_url
                ? <a class="alt-card" href={alt.product_url} target="_blank" rel="noopener">{altCard}</a>
                : <div class="alt-card">{altCard}</div>;
            })}
          </div>
        </section>
      )}

      {upsell.length > 0 && (
        <section class="upsell">
          <h2>Upsell considered</h2>
          <div class="alt-grid">
            {upsell.map((u) => {
              const uImageStyle = u.image_url ? `background-image: url('${u.image_url}');` : '';
              const uCard = (
                <>
                  <div class="alt-head">
                    <div class="alt-image" style={uImageStyle}></div>
                    <div class="alt-info">
                      <p class="alt-brand">{u.brand ?? u.provider}</p>
                      {u.model && <p class="alt-model">{u.model}</p>}
                      {u.price_ils && <p class="alt-price">&#8362;{u.price_ils.toLocaleString()}</p>}
                      {u.reviews?.average_score !== undefined && (
                        <p class="alt-reviews">
                          <span class="stars">{stars(u.reviews.average_score, u.reviews.score_max ?? 5)}</span>
                          <span>{u.reviews.average_score.toFixed(1)}</span>
                          {u.reviews.total_reviews !== undefined && <span>&middot; {u.reviews.total_reviews}</span>}
                        </p>
                      )}
                    </div>
                  </div>
                  {u.why_skipped && <p class="alt-why" set:html={inline(u.why_skipped)} />}
                </>
              );
              return u.product_url
                ? <a class="alt-card" href={u.product_url} target="_blank" rel="noopener">{uCard}</a>
                : <div class="alt-card">{uCard}</div>;
            })}
          </div>
        </section>
      )}

      {Object.keys(constraints).length > 0 && (
        <section>
          <h2>Constraints</h2>
          <dl class="house-meta">
            {Object.entries(constraints).map(([k, v]) => (
              <><dt>{k.replace(/_/g, ' ')}</dt><dd>{Array.isArray(v) ? v.join(', ') : String(v)}</dd></>
            ))}
          </dl>
        </section>
      )}

      {(energy.kwh_per_year || energy.est_annual_cost_ils) && (
        <section>
          <h2>Energy</h2>
          <dl class="house-meta">
            {energy.kwh_per_year && <><dt>kWh/year</dt><dd>{energy.kwh_per_year}</dd></>}
            {energy.est_annual_cost_ils && <><dt>Est. annual cost</dt><dd>&#8362;{energy.est_annual_cost_ils}</dd></>}
          </dl>
        </section>
      )}
    </div>

    <aside>
      {(selected.brand || selected.provider) && (
        <div class="selected-card">
          <div class="selected-image" style={selectedImageStyle}></div>
          <div class="selected-body">
            <p class="brand"><strong>{selected.brand ?? selected.provider}</strong></p>
            {selected.model && <p class="model">{selected.model}</p>}
            {selected.price_ils && <p class="price">&#8362;{selected.price_ils.toLocaleString()}</p>}
            {selected.monthly_ils && <p class="price">&#8362;{selected.monthly_ils}/month</p>}
            {selected.product_url && (
              <a class="vendor-link" href={selected.product_url} target="_blank" rel="noopener">
                Buy at {selected.vendor ?? 'vendor'} &rarr;
              </a>
            )}
            {verifiedDays !== undefined && (
              <p class={`verified-meta ${verifiedStale ? 'stale' : ''}`}>
                {verifiedStale
                  ? `Link not re-verified in ${verifiedDays} days — may be stale`
                  : verifiedDays === 0
                    ? 'Link verified today'
                    : `Link verified ${verifiedDays} ${verifiedDays === 1 ? 'day' : 'days'} ago`}
              </p>
            )}
            <dl>
              {selected.warranty && <><dt>Warranty</dt><dd>{selected.warranty}</dd></>}
              {selected.tashlumim_available && <><dt>Tashlumim</dt><dd>{selected.tashlumim_available} interest-free</dd></>}
              {item.decision_date && <><dt>Decided</dt><dd>{formatDate(item.decision_date)}</dd></>}
              {item.expected_lifespan_years && <><dt>Lifespan</dt><dd>{item.expected_lifespan_years} years</dd></>}
              {item.replacement_due && <><dt>Replace by</dt><dd>{formatDate(item.replacement_due)}</dd></>}
            </dl>
          </div>
        </div>
      )}
    </aside>
  </div>

  <div class="action-row">
    <button class="refresh-btn" id="refresh-prices" type="button">
      &#8634; Refresh prices via Claude Code
    </button>
    <span class="refresh-hint" id="refresh-hint"></span>
  </div>

  <p class="edit-hint">
    To edit, open <code>houses/{house.slug}/items/{item.slug}.md</code> in your editor &mdash; or ask Claude Code: <code>Update the {item.title.toLowerCase()} for {house.name}</code>.
  </p>

  <script is:inline define:vars={{ itemTitle: item.title, houseName: house.name, itemSlug: item.slug, houseSlug: house.slug, itemPath: item.type === 'book' ? `services/one-time/${item.slug}.md` : item.type === 'subscribe' ? `services/recurring/${item.slug}.md` : `items/${item.slug}.md` }}>
    (function () {
      const btn = document.getElementById('refresh-prices');
      const hint = document.getElementById('refresh-hint');
      if (!btn) return;
      btn.addEventListener('click', async () => {
        const prompt = `Refresh prices and links for "${itemTitle}" in "${houseName}".

Re-run the IL availability search per skills/market/il.md (Hebrew search + popularity sort + WebFetch verification). For the selected option and each entry in alternatives_considered and upsell_considered:
1. Re-verify product_url with WebFetch — confirm vendors are listed
2. Update price_ils with the current cheapest verified price
3. Update link_verified_date to today
4. If the SKU is no longer in IL retail, find the closest current equivalent and update model + product_url

Item file: houses/${houseSlug}/${itemPath}`;
        try {
          await navigator.clipboard.writeText(prompt);
          if (hint) {
            hint.textContent = '✓ Prompt copied — paste into Claude Code';
            hint.className = 'refresh-hint ok';
            setTimeout(() => { hint.textContent = ''; hint.className = 'refresh-hint'; }, 4000);
          }
        } catch (e) {
          if (hint) {
            hint.textContent = 'Copy failed — see console';
            hint.className = 'refresh-hint err';
          }
          console.log('Refresh prompt:\n' + prompt);
        }
      });
    })();
  </script>
</Layout>
