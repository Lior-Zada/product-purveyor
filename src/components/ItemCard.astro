---
import type { Item } from '../lib/houses';
import { stars } from '../lib/houses';
const { item } = Astro.props as { item: Item };
const selected = item.selected ?? {};
const priceLabel = selected.monthly_ils
  ? `₪${selected.monthly_ils}/mo`
  : selected.price_ils
    ? `₪${selected.price_ils.toLocaleString()}`
    : null;
const reviews = selected.reviews;
function stripInlineMarkdown(s: string): string {
  return s
    .replace(/\*\*(.+?)\*\*/g, '$1')        // **bold**
    .replace(/__(.+?)__/g, '$1')             // __bold__
    .replace(/(?<!\*)\*([^*]+?)\*(?!\*)/g, '$1')  // *italic*
    .replace(/(?<!_)_([^_]+?)_(?!_)/g, '$1') // _italic_
    .replace(/`([^`]+?)`/g, '$1')            // `code`
    .replace(/&mdash;/g, '—')
    .replace(/&ndash;/g, '–')
    .replace(/&amp;/g, '&')
    .replace(/&hellip;/g, '…')
    .replace(/&quot;/g, '"')
    .replace(/&ldquo;|&rdquo;/g, '"')
    .replace(/&lsquo;|&rsquo;/g, "'")
    .replace(/&#8362;|&pound;/g, '₪')       // shekel (the &pound; is a typo guard)
    .replace(/&#8212;/g, '—')
    .replace(/&#8211;/g, '–');
}

const firstLine = item.body
  ? stripInlineMarkdown(
      item.body
        .split('\n')
        .map((l) => l.trim())
        .filter((l) => l && !l.startsWith('#'))
        .slice(0, 2)
        .join(' ')
        .replace(/^[-*]\s*/, ''),
    ).slice(0, 160)
  : '';
const imageStyle = selected.image_url ? `background-image: url('${selected.image_url}');` : '';
---
<a class={`card status-${item.status}`} href={`/${item.house}/items/${item.slug}/`}>
  <div class="card-image" style={imageStyle}></div>
  <div class="card-body">
    <div class="card-head">
      <span class={`badge status-${item.status}`}>{item.status}</span>
      {item.priority && <span class="badge priority">{item.priority}</span>}
    </div>
    <h3>{item.title}</h3>
    {(selected.brand || selected.provider) && (
      <p class="pick">
        <strong>{selected.brand ?? selected.provider}</strong>
        {selected.model && <> &middot; {selected.model}</>}
      </p>
    )}
    {priceLabel && <p class="price">{priceLabel}</p>}
    {reviews?.average_score !== undefined && (
      <p class="reviews-inline">
        <span class="stars">{stars(reviews.average_score, reviews.score_max ?? 5)}</span>
        <span>{reviews.average_score.toFixed(1)}</span>
        {reviews.total_reviews !== undefined && <span>&middot; {reviews.total_reviews.toLocaleString()} reviews</span>}
      </p>
    )}
    {firstLine && <p class="rationale">{firstLine}</p>}
  </div>
</a>
